@page
@model MarvelManager.Pages.Characters.IndexModel

@{
    ViewData["Title"] = "Personnages Marvel";
}

<h1>Personnages Marvel</h1>

<form method="get" class="mb-3">
    <div class="input-group">
        <input type="text"
               name="search"
               value="@Model.Search"
               class="form-control"
               placeholder="Rechercher un personnage, une équipe..." />

        <button type="submit" class="btn btn-primary">
            Rechercher
        </button>
    </div>
</form>

<a class="btn btn-primary mb-3" asp-page="/Characters/Create">
    Ajouter un personnage
</a>

<a class="btn btn-success mb-3"
   asp-page="/Characters/ExportCsv">
    Exporter CSV
</a>

<table class="table table-striped">
    <thead>
    <tr>
        <th>Héros</th>
        <th>Nom réel</th>
        <th>Pouvoir</th>
        <th>Niveau</th>
        <th>Équipe</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var character in Model.Characters)
    {
        <tr>
            <td>@character.HeroName</td>
            <td>@character.Name</td>
            <td>@character.Power</td>
            <td>@character.PowerLevel</td>
            <td>@character.TeamName</td>
            <td>
                <a class="btn btn-sm btn-info"
                   asp-page="/Characters/Details"
                   asp-route-id="@character.Id">
                    Détails
                </a>
                <a class="btn btn-sm btn-warning"
                   asp-page="/Characters/Edit"
                   asp-route-id="@character.Id">
                    Modifier
                </a>
                <a class="btn btn-sm btn-danger"
                   asp-page="/Characters/Delete"
                   asp-route-id="@character.Id">
                    Supprimer
                </a>
                
            </td>
            
        </tr>
    }
    </tbody>
</table>
<nav>
    <ul class="pagination">

        @if (Model.CurrentPage > 1)
        {
            <li class="page-item">
                <a class="page-link"
                   asp-page="/Characters/Index"
                   asp-route-search="@Model.Search"
                   asp-route-pageNumber="@(Model.CurrentPage - 1)">
                    Précédent
                </a>
            </li>
        }

        <li class="page-item active">
            <span class="page-link">
                Page @Model.CurrentPage / @Model.TotalPages
            </span>
        </li>

        @if (Model.CurrentPage < Model.TotalPages)
        {
            <li class="page-item">
                <a class="page-link"
                   asp-page="/Characters/Index"
                   asp-route-search="@Model.Search"
                   asp-route-pageNumber="@(Model.CurrentPage + 1)">
                    Suivant
                </a>
            </li>
        }

    </ul>
</nav>