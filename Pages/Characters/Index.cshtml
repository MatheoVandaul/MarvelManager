@page
@model MarvelManager.Pages.Characters.IndexModel

@{
    ViewData["Title"] = "Personnages Marvel";
}


<div class="search-section mb-5">

    <h2 class="search-title">
        Explorer les personnages Marvel
    </h2>

    <p class="search-subtitle">
        Recherchez un héros, un nom réel ou une équipe.
    </p>

    <form method="get">

        <div class="search-bar-container">

            <input type="text"
                   name="search"
                   value="@Model.Search"
                   class="search-input"
                   placeholder="Iron Man, Avengers, Wolverine..." />

            <button type="submit" class="search-button">
                Rechercher
            </button>

        </div>

    </form>

</div>
@if (User.IsInRole("Admin"))
{
    <a class="btn btn-primary mb-3" asp-page="/Characters/Create">
        Ajouter un personnage
    </a>
}

<a class="btn btn-success mb-3"
   asp-page="/Characters/ExportCsv">
    Exporter CSV
</a>

<div class="row">
    @foreach (var character in Model.Characters)
    {
        <div class="col-md-4 mb-4">
            <div class="card character-card h-100">
                @if (!string.IsNullOrEmpty(character.ImageUrl))
                {
                    <img src="@character.ImageUrl"
                         class="card-img-top character-image"
                         alt="@character.HeroName" />
                }
                <div class="card-body">
                    <h5 class="card-title text-danger fw-bold">
                        @character.HeroName
                    </h5>

                    <h6 class="card-subtitle mb-2 text-light">
                        @character.Name
                    </h6>

                    <p class="card-text">
                        <strong>Pouvoir :</strong> @character.Power<br/>
                        <strong>Niveau :</strong> @character.PowerLevel / 100<br/>
                        <strong>Équipe :</strong> @character.TeamName
                    </p>

                    <a class="btn btn-sm btn-info"
                       asp-page="/Characters/Details"
                       asp-route-id="@character.Id">
                        Détails
                    </a>

                    @if (User.IsInRole("Admin"))
                    {
                        <a class="btn btn-sm btn-warning"
                           asp-page="/Characters/Edit"
                           asp-route-id="@character.Id">
                            Modifier
                        </a>

                        <a class="btn btn-sm btn-danger"
                           asp-page="/Characters/Delete"
                           asp-route-id="@character.Id">
                            Supprimer
                        </a>
                    }
                </div>
            </div>
        </div>
    }
</div>
<nav>
    <ul class="pagination">

        @if (Model.CurrentPage > 1)
        {
            <li class="page-item">
                <a class="page-link"
                   asp-page="/Characters/Index"
                   asp-route-search="@Model.Search"
                   asp-route-pageNumber="@(Model.CurrentPage - 1)">
                    Précédent
                </a>
            </li>
        }

        <li class="page-item active">
            <span class="page-link">
                Page @Model.CurrentPage / @Model.TotalPages
            </span>
        </li>

        @if (Model.CurrentPage < Model.TotalPages)
        {
            <li class="page-item">
                <a class="page-link"
                   asp-page="/Characters/Index"
                   asp-route-search="@Model.Search"
                   asp-route-pageNumber="@(Model.CurrentPage + 1)">
                    Suivant
                </a>
            </li>
        }

    </ul>
</nav>