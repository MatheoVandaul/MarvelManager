@page
@model MarvelManager.Pages.Account.RegisterModel

@{
    ViewData["Title"] = "Inscription";
}

<div class="auth-container">
    <div class="auth-card">

        <h1>Inscription</h1>
        <p class="auth-subtitle">Créez votre compte Marvel Manager</p>

        @if (Model.ErrorMessage != null)
        {
            <div class="alert alert-danger">
                @Model.ErrorMessage
            </div>
        }

        <form method="post">
            <div class="mb-3">
                <label asp-for="Name" class="form-label">Nom</label>
                <input asp-for="Name" class="form-control" placeholder="Votre nom" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-control" placeholder="exemple@email.com" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="Password" class="form-label">Mot de passe</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Minimum 6 caractères" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-danger w-100">
                Créer le compte
            </button>
        </form>

        <p class="auth-link">
            Déjà un compte ?
            <a asp-page="/Account/Login">Se connecter</a>
        </p>

    </div>
</div>