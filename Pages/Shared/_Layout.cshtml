<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MarvelManager</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@600;700&family=Source+Sans+3:wght@400;600&display=swap" rel="stylesheet">
</head>
<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand text-white" asp-area="" asp-page="/Index">MARVEL UNIVERSE MANAGER</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link nav-marvel" asp-page="/Index">
                                Accueil
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link nav-marvel" asp-page="/Characters/Index">
                                Personnages
                            </a>
                        </li>
                    </ul>

                    <ul class="navbar-nav ms-auto">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-white">
                                    Bonjour @User.Identity.Name
                                </span>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link nav-marvel" asp-page="/Account/Logout">
                                    Déconnexion
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-marvel" asp-page="/Account/Login">
                                    Connexion
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link nav-marvel" asp-page="/Account/Register">
                                    Inscription
                                </a>
                            </li>
                        }
                    </ul>

                </div>
            </div>
        </nav>
    </header>
<div class="container flex-fill py-4">
    <main role="main">
        @RenderBody()
    </main>
</div>

<footer class="footer-marvel mt-auto py-4">

    <div class="container text-center">

        <h5 class="text-danger fw-bold mb-3">
            MARVEL UNIVERSE MANAGER
        </h5>

        <p class="mb-2">
            Application ASP.NET Core Razor Pages
        </p>

        <p class="mb-2">
            Projet réalisé avec PostgreSQL, ADO.NET et authentification sécurisée.
        </p>

        <small class="text-secondary">
            © 2026 - Marvel Universe Manager
        </small>

    </div>

</footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
